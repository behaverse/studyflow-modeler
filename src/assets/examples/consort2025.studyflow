<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:studyflow="http://behaverse.org/schemas/studyflow" xmlns:cognitive="http://behaverse.org/schemas/studyflow/cognitive" id="consort2025-example" targetNamespace="http://bpmn.io/schema/bpmn" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd">
  <bpmn2:process id="CONSORT_2025" isExecutable="false">
    <bpmn2:extensionElements>
      <studyflow:study />
    </bpmn2:extensionElements>
    <bpmn2:documentation>A CONSORT 2025-compliant randomized controlled trial covering enrollment, allocation, intervention, follow-up, and analysis.</bpmn2:documentation>
    <bpmn2:startEvent id="Enrollment_Start" name="Enrollment" studyflow:consentFormUri="https://example.org/protocols/consort2025/consent.pdf">
      <bpmn2:outgoing>Flow_Start_Screening</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:task id="Activity_Screening" studyflow:checklist="- [ ] Demographic intake&#10;- [ ] Medical history&#10;- [ ] Vital signs&#10;- [ ] Baseline cognitive screen" name="Screening assessment">
      <bpmn2:extensionElements>
        <cognitive:questionnaire instrument="screening" />
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_Start_Screening</bpmn2:incoming>
      <bpmn2:outgoing>Flow_Screening_Eligibility</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:exclusiveGateway id="Eligibility_Gateway" name="Assessed for eligibility">
      <bpmn2:extensionElements>
        <cognitive:eligibilityGateway />
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_Screening_Eligibility</bpmn2:incoming>
      <bpmn2:outgoing>Flow_Eligible</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_Excluded_Pre</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:endEvent id="Excluded_Pre" name="Excluded (n=...)">
      <bpmn2:incoming>Flow_Excluded_Pre</bpmn2:incoming>
      <bpmn2:errorEventDefinition id="ErrorDef_ExcludedPre" />
    </bpmn2:endEvent>
    <bpmn2:exclusiveGateway id="Randomize_Gateway" name="Randomization">
      <bpmn2:extensionElements>
        <cognitive:randomGateway />
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_Eligible</bpmn2:incoming>
      <bpmn2:outgoing>Flow_Allocate_A</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_Allocate_B</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:task id="Activity_Allocation_A" studyflow:checklist="- [ ] Allocation concealed until enrollment&#10;- [ ] Intervention delivered as protocol&#10;- [ ] Adverse events recorded" name="Allocated to intervention (n=...)">
      <bpmn2:incoming>Flow_Allocate_A</bpmn2:incoming>
      <bpmn2:outgoing>Flow_A_Followup</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:boundaryEvent id="DidNotReceive_A" name="Did not receive (n=...)" attachedToRef="Activity_Allocation_A">
      <bpmn2:outgoing>Flow_DidNotReceive_A</bpmn2:outgoing>
      <bpmn2:errorEventDefinition id="ErrorDef_DidNotReceive_A" />
    </bpmn2:boundaryEvent>
    <bpmn2:task id="Activity_Followup_A" studyflow:checklist="- [ ] Adherence visit&#10;- [ ] Outcome assessment 1&#10;- [ ] Outcome assessment 2&#10;- [ ] Adverse events review" name="Follow-up">
      <bpmn2:extensionElements>
        <cognitive:cognitiveTask instrument="jspsych"># n-back primary outcome
duration: 10
n_back_levels: [1, 2, 3]
trials_per_block: 30
</cognitive:cognitiveTask>
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_A_Followup</bpmn2:incoming>
      <bpmn2:outgoing>Flow_A_Analysis</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:boundaryEvent id="LostFollowup_A" name="Lost to follow-up (n=...)" attachedToRef="Activity_Followup_A">
      <bpmn2:outgoing>Flow_LostFollowup_A</bpmn2:outgoing>
      <bpmn2:errorEventDefinition id="ErrorDef_Lost_A" />
    </bpmn2:boundaryEvent>
    <bpmn2:boundaryEvent id="Discontinued_A" name="Discontinued (n=...)" attachedToRef="Activity_Followup_A">
      <bpmn2:outgoing>Flow_Discontinued_A</bpmn2:outgoing>
      <bpmn2:errorEventDefinition id="ErrorDef_Discont_A" />
    </bpmn2:boundaryEvent>
    <bpmn2:task id="Activity_Analysis_A" studyflow:checklist="- [ ] Intention-to-treat dataset&#10;- [ ] Per-protocol dataset&#10;- [ ] Sensitivity analyses&#10;- [ ] Pre-registered statistical plan applied" name="Analyzed (n=...)">
      <bpmn2:incoming>Flow_A_Analysis</bpmn2:incoming>
      <bpmn2:outgoing>Flow_A_Done</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:boundaryEvent id="ExcludedFromAnalysis_A" name="Excluded from analysis (n=...)" attachedToRef="Activity_Analysis_A">
      <bpmn2:outgoing>Flow_ExcludedAnalysis_A</bpmn2:outgoing>
      <bpmn2:errorEventDefinition id="ErrorDef_AnalysisExcluded_A" />
    </bpmn2:boundaryEvent>
    <bpmn2:task id="Activity_Allocation_B" studyflow:checklist="- [ ] Allocation concealed until enrollment&#10;- [ ] Sham/usual-care delivered as protocol&#10;- [ ] Adverse events recorded" name="Allocated to control (n=...)">
      <bpmn2:incoming>Flow_Allocate_B</bpmn2:incoming>
      <bpmn2:outgoing>Flow_B_Followup</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:boundaryEvent id="DidNotReceive_B" name="Did not receive (n=...)" attachedToRef="Activity_Allocation_B">
      <bpmn2:outgoing>Flow_DidNotReceive_B</bpmn2:outgoing>
      <bpmn2:errorEventDefinition id="ErrorDef_DidNotReceive_B" />
    </bpmn2:boundaryEvent>
    <bpmn2:task id="Activity_Followup_B" studyflow:checklist="- [ ] Adherence visit&#10;- [ ] Outcome assessment 1&#10;- [ ] Outcome assessment 2&#10;- [ ] Adverse events review" name="Follow-up">
      <bpmn2:extensionElements>
        <cognitive:rest># Resting baseline used as control condition
duration_min: 10
eyes_open: true
</cognitive:rest>
      </bpmn2:extensionElements>
      <bpmn2:incoming>Flow_B_Followup</bpmn2:incoming>
      <bpmn2:outgoing>Flow_B_Analysis</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:boundaryEvent id="LostFollowup_B" name="Lost to follow-up (n=...)" attachedToRef="Activity_Followup_B">
      <bpmn2:outgoing>Flow_LostFollowup_B</bpmn2:outgoing>
      <bpmn2:errorEventDefinition id="ErrorDef_Lost_B" />
    </bpmn2:boundaryEvent>
    <bpmn2:boundaryEvent id="Discontinued_B" name="Discontinued (n=...)" attachedToRef="Activity_Followup_B">
      <bpmn2:outgoing>Flow_Discontinued_B</bpmn2:outgoing>
      <bpmn2:errorEventDefinition id="ErrorDef_Discont_B" />
    </bpmn2:boundaryEvent>
    <bpmn2:task id="Activity_Analysis_B" studyflow:checklist="- [ ] Intention-to-treat dataset&#10;- [ ] Per-protocol dataset&#10;- [ ] Sensitivity analyses&#10;- [ ] Pre-registered statistical plan applied" name="Analyzed (n=...)">
      <bpmn2:incoming>Flow_B_Analysis</bpmn2:incoming>
      <bpmn2:outgoing>Flow_B_Done</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:boundaryEvent id="ExcludedFromAnalysis_B" name="Excluded from analysis (n=...)" attachedToRef="Activity_Analysis_B">
      <bpmn2:outgoing>Flow_ExcludedAnalysis_B</bpmn2:outgoing>
      <bpmn2:errorEventDefinition id="ErrorDef_AnalysisExcluded_B" />
    </bpmn2:boundaryEvent>
    <bpmn2:endEvent id="Trial_Complete" name="Completed" studyflow:redirectTo="https://app.prolific.com/submissions/complete?cc={COMPLETION_CODE}" studyflow:completionCodeType="dynamic">
      <bpmn2:incoming>Flow_A_Done</bpmn2:incoming>
      <bpmn2:incoming>Flow_B_Done</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:endEvent id="Excluded_Post" name="Excluded (n=...)">
      <bpmn2:incoming>Flow_DidNotReceive_A</bpmn2:incoming>
      <bpmn2:incoming>Flow_LostFollowup_A</bpmn2:incoming>
      <bpmn2:incoming>Flow_Discontinued_A</bpmn2:incoming>
      <bpmn2:incoming>Flow_ExcludedAnalysis_A</bpmn2:incoming>
      <bpmn2:incoming>Flow_DidNotReceive_B</bpmn2:incoming>
      <bpmn2:incoming>Flow_LostFollowup_B</bpmn2:incoming>
      <bpmn2:incoming>Flow_Discontinued_B</bpmn2:incoming>
      <bpmn2:incoming>Flow_ExcludedAnalysis_B</bpmn2:incoming>
      <bpmn2:errorEventDefinition id="ErrorDef_ExcludedPost" />
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="Flow_Start_Screening" sourceRef="Enrollment_Start" targetRef="Activity_Screening" />
    <bpmn2:sequenceFlow id="Flow_Screening_Eligibility" sourceRef="Activity_Screening" targetRef="Eligibility_Gateway" />
    <bpmn2:sequenceFlow id="Flow_Eligible" name="eligible" sourceRef="Eligibility_Gateway" targetRef="Randomize_Gateway" />
    <bpmn2:sequenceFlow id="Flow_Excluded_Pre" name="not eligible" sourceRef="Eligibility_Gateway" targetRef="Excluded_Pre" />
    <bpmn2:sequenceFlow id="Flow_Allocate_A" name="intervention" sourceRef="Randomize_Gateway" targetRef="Activity_Allocation_A" />
    <bpmn2:sequenceFlow id="Flow_Allocate_B" name="control" sourceRef="Randomize_Gateway" targetRef="Activity_Allocation_B" />
    <bpmn2:sequenceFlow id="Flow_A_Followup" sourceRef="Activity_Allocation_A" targetRef="Activity_Followup_A" />
    <bpmn2:sequenceFlow id="Flow_A_Analysis" sourceRef="Activity_Followup_A" targetRef="Activity_Analysis_A" />
    <bpmn2:sequenceFlow id="Flow_A_Done" sourceRef="Activity_Analysis_A" targetRef="Trial_Complete" />
    <bpmn2:sequenceFlow id="Flow_B_Followup" sourceRef="Activity_Allocation_B" targetRef="Activity_Followup_B" />
    <bpmn2:sequenceFlow id="Flow_B_Analysis" sourceRef="Activity_Followup_B" targetRef="Activity_Analysis_B" />
    <bpmn2:sequenceFlow id="Flow_B_Done" sourceRef="Activity_Analysis_B" targetRef="Trial_Complete" />
    <bpmn2:sequenceFlow id="Flow_DidNotReceive_A" name="reason" sourceRef="DidNotReceive_A" targetRef="Excluded_Post" />
    <bpmn2:sequenceFlow id="Flow_LostFollowup_A" name="reason" sourceRef="LostFollowup_A" targetRef="Excluded_Post" />
    <bpmn2:sequenceFlow id="Flow_Discontinued_A" sourceRef="Discontinued_A" targetRef="Excluded_Post" />
    <bpmn2:sequenceFlow id="Flow_ExcludedAnalysis_A" name="reason" sourceRef="ExcludedFromAnalysis_A" targetRef="Excluded_Post" />
    <bpmn2:sequenceFlow id="Flow_DidNotReceive_B" name="reason" sourceRef="DidNotReceive_B" targetRef="Excluded_Post" />
    <bpmn2:sequenceFlow id="Flow_LostFollowup_B" name="reason" sourceRef="LostFollowup_B" targetRef="Excluded_Post" />
    <bpmn2:sequenceFlow id="Flow_Discontinued_B" name="reason" sourceRef="Discontinued_B" targetRef="Excluded_Post" />
    <bpmn2:sequenceFlow id="Flow_ExcludedAnalysis_B" name="reason" sourceRef="ExcludedFromAnalysis_B" targetRef="Excluded_Post" />
    <bpmn2:group id="Group_Enrollment" categoryValueRef="CategoryValue_Enrollment" />
    <bpmn2:group id="Group_Allocation" categoryValueRef="CategoryValue_Allocation" />
    <bpmn2:group id="Group_Followup" categoryValueRef="CategoryValue_Followup" />
    <bpmn2:group id="Group_Analysis" categoryValueRef="CategoryValue_Analysis" />
  </bpmn2:process>
  <bpmn2:category id="Category_Enrollment">
    <bpmn2:categoryValue id="CategoryValue_Enrollment" value="Enrollment" />
  </bpmn2:category>
  <bpmn2:category id="Category_Allocation">
    <bpmn2:categoryValue id="CategoryValue_Allocation" value="Allocation" />
  </bpmn2:category>
  <bpmn2:category id="Category_Followup">
    <bpmn2:categoryValue id="CategoryValue_Followup" value="Follow-up" />
  </bpmn2:category>
  <bpmn2:category id="Category_Analysis">
    <bpmn2:categoryValue id="CategoryValue_Analysis" value="Analysis" />
  </bpmn2:category>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="CONSORT_2025_RCT">
