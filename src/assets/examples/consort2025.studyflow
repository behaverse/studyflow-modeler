      <bpmndi:BPMNEdge id="Flow_Allocate_B_di" bpmnElement="Flow_Allocate_B">
        <di:waypoint x="455" y="450" />
        <di:waypoint x="580" y="450" />
        <di:waypoint x="580" y="490" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="500" y="432" width="40" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A_Followup_di" bpmnElement="Flow_A_Followup">
        <di:waypoint x="280" y="570" />
        <di:waypoint x="280" y="630" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A_Analysis_di" bpmnElement="Flow_A_Analysis">
        <di:waypoint x="280" y="710" />
        <di:waypoint x="280" y="800" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_A_Done_di" bpmnElement="Flow_A_Done">
