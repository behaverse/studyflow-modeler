      extensionElements:
        - type: datatrove:Document
      name: Document
      bounds:
        x: 340
        "y": 2064
        width: 50
        height: 50
  artifacts:
    Bd_Annotation:
      type: bpmn:TextAnnotation
      text: A free-form note. Groups (these labelled bands) are artifacts too.
      name: Text annotation
      bounds:
