Category_BpmnEvents:
  type: bpmn:Category
  categoryValue:
    CategoryValue_BpmnEvents:
      value: BPMN · Events
Category_BpmnGateways:
  type: bpmn:Category
  categoryValue:
    CategoryValue_BpmnGateways:
      value: BPMN · Gateways
Category_BpmnActivities:
  type: bpmn:Category
  categoryValue:
    CategoryValue_BpmnActivities:
      value: BPMN · Activities
Category_BpmnData:
  type: bpmn:Category
  categoryValue:
    CategoryValue_BpmnData:
      value: BPMN · Data & artifacts
Category_Studyflow:
  type: bpmn:Category
  categoryValue:
    CategoryValue_Studyflow:
      value: studyflow · Core data elements (BDM, BIDS, Psych-DS, CSVW)
Category_Exec:
  type: bpmn:Category
  categoryValue:
    CategoryValue_Exec:
      value: exec · Execution & scope
Category_Cognitive:
  type: bpmn:Category
  categoryValue:
    CategoryValue_Cognitive:
      value: cognitive · Domain activities & research gateways (incl. Behaverse)
Category_Ml:
  type: bpmn:Category
  categoryValue:
    CategoryValue_Ml:
      value: ml · Statistical & ML pipelines
Category_OpenBCI:
  type: bpmn:Category
  categoryValue:
