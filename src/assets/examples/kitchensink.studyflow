      name: OpenBCI recording
      bounds:
        x: 765
        "y": 1594
        width: 50
        height: 50
    Ag_Agent:
      type: bpmn:AdHocSubProcess
      extensionElements:
        - type: agentic:Agent
          model: claude-opus-4-8
          maxTurns: 8
      name: Agent
      bounds:
        x: 125
        "y": 1759
        width: 120
        height: 80
      isExpanded: false
    Ag_Router:
      type: bpmn:ExclusiveGateway
      extensionElements:
        - type: agentic:Router
          model: claude-haiku-4-5
      name: Router
      bounds:
        x: 340
        "y": 1774
        width: 50
        height: 50
    Ag_LLMCall:
      type: bpmn:ServiceTask
      extensionElements:
        - type: agentic:LLMCall
          model: claude-opus-4-8
      name: LLM call
      bounds:
        x: 485
        "y": 1759
        width: 120
        height: 80
    Ag_Tool:
      type: bpmn:ServiceTask
      extensionElements:
        - type: agentic:Tool
          implementation: python://lab.rag.retrieve
          kind: retrieval
      name: Tool
      bounds:
        x: 665
        "y": 1759
        width: 120
        height: 80
    Ag_HumanApproval:
      type: bpmn:UserTask
      extensionElements:
        - type: agentic:HumanApproval
      name: Human approval
      bounds:
        x: 845
        "y": 1759
        width: 120
        height: 80
    Ag_Prompt:
      type: bpmn:DataObjectReference
      extensionElements:
        - type: agentic:Prompt
          version: "1"
      name: Prompt
      bounds:
        x: 1060
        "y": 1774
        width: 50
        height: 50
    Ag_Memory:
      type: bpmn:DataStoreReference
      extensionElements:
        - type: agentic:Memory
          scope: participant
      name: Memory
      bounds:
        x: 1240
        "y": 1774
        width: 50
        height: 50
    Dt_Transform:
      type: bpmn:ServiceTask
      extensionElements:
        - type: datatrove:Transform
          implementation: python://lab.transform
      name: Transform
      bounds:
        x: 125
        "y": 1939
        width: 120
        height: 80
    Dt_Map:
      type: bpmn:ServiceTask
      extensionElements:
        - type: datatrove:Map
      name: Map
      bounds:
        x: 305
        "y": 1939
        width: 120
        height: 80
    Dt_FlatMap:
      type: bpmn:ServiceTask
      extensionElements:
        - type: datatrove:FlatMap
      name: FlatMap
      bounds:
        x: 485
        "y": 1939
        width: 120
        height: 80
    Dt_Reduce:
      type: bpmn:ServiceTask
      extensionElements:
        - type: datatrove:Reduce
      name: Reduce
      bounds:
        x: 665
        "y": 1939
        width: 120
        height: 80
    Dt_Filter:
      type: bpmn:ServiceTask
      extensionElements:
        - type: datatrove:Filter
      name: Filter
      bounds:
        x: 845
        "y": 1939
        width: 120
        height: 80
    Dt_Compose:
      type: bpmn:ServiceTask
      extensionElements:
        - type: datatrove:Compose
      name: Compose
      bounds:
        x: 1025
        "y": 1939
        width: 120
        height: 80
    Dt_Reader:
      type: bpmn:ServiceTask
      extensionElements:
        - type: datatrove:Reader
          className: CSVReader
          path: data/raw/
      name: Reader
      bounds:
        x: 1205
        "y": 1939
        width: 120
        height: 80
    Dt_Writer:
      type: bpmn:ServiceTask
      extensionElements:
        - type: datatrove:Writer
          path: data/out/
