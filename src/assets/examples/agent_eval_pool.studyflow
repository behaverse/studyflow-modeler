id: agent_eval_pool
definitions:
  targetNamespace: http://bpmn.io/schema/bpmn
  xmlns:xsi: http://www.w3.org/2001/XMLSchema-instance
  xmlns:bpmn2: http://www.omg.org/spec/BPMN/20100524/MODEL
  xmlns:bpmndi: http://www.omg.org/spec/BPMN/20100524/DI
  xmlns:dc: http://www.omg.org/spec/DD/20100524/DC
  xmlns:di: http://www.omg.org/spec/DD/20100524/DI
  xmlns:studyflow: http://behaverse.org/schemas/studyflow/v1
  xmlns:cognitive: http://behaverse.org/schemas/studyflow/cognitive
  xmlns:behaverse: http://behaverse.org/schemas/studyflow/behaverse
Agent_Eval_Pool:
  type: bpmn:Process
  documentation: Runs one 2-back protocol on random, Claude, and Ollama agents in parallel and compares their accuracy.
  extensionElements:
    - type: studyflow:Study
  name: LLM evaluation — agent actor pool
  flowElements:
    Start:
      type: bpmn:StartEvent
      name: Load N-Back protocol
      outgoing:
        - Flow_Start_Fork
      bounds:
        x: 160
        "y": 280
        width: 36
        height: 36
      label:
        bounds:
          x: 140
          "y": 323
          width: 78
          height: 27
    Fork:
      type: bpmn:ParallelGateway
      name: Dispatch to agent pool
      incoming:
        - Flow_Start_Fork
      outgoing:
        - Flow_Fork_Random
        - Flow_Fork_Claude
        - Flow_Fork_Ollama
      bounds:
        x: 250
        "y": 273
        width: 50
        height: 50
      label:
        bounds:
          x: 236
          "y": 330
          width: 80
          height: 27
    Agent_Random:
      type: bpmn:Task
      extensionElements:
        - type: behaverse:Task
          configurations:
            Blocks:
              Eval_2Back:
                Name: Eval_2Back
                Inherits: Default
                Parameters:
                  NValue: 2
                  Feature: Letters
                  Streams:
                    - Feature:
                        Reference: Feature
                      StimulusValue:
                        Generate: OncePerBlock
                        Sequence:
                          Type: Ordered
                          Values:
                            - 3
                            - 1
                            - 2
                            - 1
                            - 3
                            - 2
                            - 3
                            - 2
                            - 1
                            - 2
                            - 3
                            - 1
                  StreamSize: 12
                  FeatureValuesCount: 3
                  MaxResponseTime: 2
                  StimulusDisplayDuration: 0.5
                  InterStimulusInterval: 1.5
            Timelines:
              Eval_2Back:
                Name: Eval_2Back
                blocks:
                  - name: Eval_2Back
          scene: NB
          agentType: bot
          botConfigurations:
            ResponseSource: external
            Speed: 20
            SkipInstructions: true
            AutoClickInstructions: true
            SkipFocusArea: true
            OverrideTemporalParameters: true
            StimulusDisplayDuration: 0.3
            InterStimulusInterval: 0.3
            TrialForeperiod: 0.1
      name: Random baseline agent
      incoming:
        - Flow_Fork_Random
      outgoing:
        - Flow_Random_Join
      bounds:
        x: 380
        "y": 100
        width: 120
        height: 80
    Agent_Claude:
      type: bpmn:Task
      extensionElements:
        - type: behaverse:Task
          configurations:
            Blocks:
              Eval_2Back:
                Name: Eval_2Back
                Inherits: Default
                Parameters:
                  NValue: 2
                  Feature: Letters
                  Streams:
                    - Feature:
                        Reference: Feature
                      StimulusValue:
                        Generate: OncePerBlock
                        Sequence:
                          Type: Ordered
                          Values:
                            - 3
                            - 1
                            - 2
                            - 1
                            - 3
                            - 2
                            - 3
                            - 2
                            - 1
                            - 2
                            - 3
                            - 1
                  StreamSize: 12
                  FeatureValuesCount: 3
                  MaxResponseTime: 30
                  StimulusDisplayDuration: 0.5
                  InterStimulusInterval: 1.5
            Timelines:
              Eval_2Back:
                Name: Eval_2Back
                blocks:
                  - name: Eval_2Back
          scene: NB
          agentType: bot
          botConfigurations:
            ResponseSource: llm
            LLM:
              Provider: claude
              Model: claude-haiku-4-5
            Prompt: |
              You are an attentive, expert participant in a 2-back task.
              Respond Match if the current letter is identical to the letter shown
              exactly two trials ago, otherwise NonMatch. Aim for near-perfect
              accuracy. Reply with exactly Match or NonMatch; no explanation.
            Speed: 20
            SkipInstructions: true
            AutoClickInstructions: true
            SkipFocusArea: true
            OverrideTemporalParameters: true
            StimulusDisplayDuration: 0.3
            InterStimulusInterval: 0.3
            TrialForeperiod: 0.1
            overrideUserInputParameters: true
            playerPaced: true
            useNonMatchButton: true
            maxResponseTime: 120
      name: Claude LLM agent
      incoming:
        - Flow_Fork_Claude
      outgoing:
        - Flow_Claude_Join
      bounds:
        x: 380
        "y": 258
        width: 120
        height: 80
    Agent_Ollama:
      type: bpmn:Task
      extensionElements:
        - type: behaverse:Task
          configurations:
            Blocks:
              Eval_2Back:
                Name: Eval_2Back
                Inherits: Default
                Parameters:
                  NValue: 2
                  Feature: Letters
                  Streams:
                    - Feature:
                        Reference: Feature
                      StimulusValue:
                        Generate: OncePerBlock
                        Sequence:
                          Type: Ordered
                          Values:
                            - 3
                            - 1
                            - 2
                            - 1
                            - 3
                            - 2
                            - 3
                            - 2
                            - 1
                            - 2
                            - 3
                            - 1
                  StreamSize: 12
                  FeatureValuesCount: 3
                  MaxResponseTime: 15
                  StimulusDisplayDuration: 0.5
                  InterStimulusInterval: 1.5
            Timelines:
              Eval_2Back:
                Name: Eval_2Back
                blocks:
                  - name: Eval_2Back
          scene: NB
          agentType: bot
          botConfigurations:
            ResponseSource: llm
            LLM:
              Provider: ollama
              Model: gemma4:e2b-mlx
            Prompt: |
              You are an attentive, expert participant in a 2-back task.
              Respond Match if the current letter is identical to the letter shown
              exactly two trials ago, otherwise NonMatch. Aim for near-perfect
              accuracy. Reply with exactly Match or NonMatch; no explanation.
            Speed: 20
            SkipInstructions: true
            AutoClickInstructions: true
            SkipFocusArea: true
            OverrideTemporalParameters: true
            StimulusDisplayDuration: 0.3
            InterStimulusInterval: 0.3
            TrialForeperiod: 0.1
            overrideUserInputParameters: true
            playerPaced: true
            useNonMatchButton: true
            maxResponseTime: 15
      name: Ollama LLM agent (local)
      incoming:
        - Flow_Fork_Ollama
      outgoing:
        - Flow_Ollama_Join
      bounds:
        x: 380
        "y": 420
        width: 120
        height: 80
    Join:
      type: bpmn:ParallelGateway
      name: Collect responses
      incoming:
        - Flow_Random_Join
        - Flow_Claude_Join
        - Flow_Ollama_Join
      outgoing:
        - Flow_Join_Score
      bounds:
        x: 560
        "y": 273
        width: 50
        height: 50
      label:
        bounds:
          x: 548
          "y": 330
          width: 76
          height: 14
    Score:
      type: bpmn:Task
      checklist: |-
        - [ ] Compute hit rate / false-alarm rate per agent
        - [ ] Compute d-prime per agent
        - [ ] Compare each model to the random baseline
        - [ ] Compare models to human norms
      name: Aggregate & compare accuracy
      incoming:
        - Flow_Join_Score
      outgoing:
        - Flow_Score_End
      bounds:
        x: 660
        "y": 258
        width: 140
        height: 80
    Dataset_Responses:
      type: bpmn:DataStoreReference
      extensionElements:
        - type: studyflow:Dataset
          format: bdm
          bdmDataLevel: trials
      name: Agent response set
      bounds:
        x: 705
        "y": 430
        width: 50
        height: 50
      label:
        bounds:
          x: 688
          "y": 485
          width: 84
          height: 14
    End:
      type: bpmn:EndEvent
      name: Evaluation report
      incoming:
        - Flow_Score_End
      bounds:
        x: 860
        "y": 280
        width: 36
        height: 36
      label:
        bounds:
          x: 838
          "y": 323
          width: 82
          height: 14
    Flow_Start_Fork:
      type: bpmn:SequenceFlow
      sourceRef: Start
      targetRef: Fork
      waypoint:
        - x: 196
          "y": 298
        - x: 250
          "y": 298
    Flow_Fork_Random:
      type: bpmn:SequenceFlow
      sourceRef: Fork
      targetRef: Agent_Random
      waypoint:
        - x: 300
          "y": 298
        - x: 340
          "y": 298
        - x: 340
          "y": 140
        - x: 380
          "y": 140
    Flow_Fork_Claude:
      type: bpmn:SequenceFlow
      sourceRef: Fork
      targetRef: Agent_Claude
      waypoint:
        - x: 300
          "y": 298
        - x: 380
          "y": 298
    Flow_Fork_Ollama:
      type: bpmn:SequenceFlow
      sourceRef: Fork
      targetRef: Agent_Ollama
      waypoint:
        - x: 300
          "y": 298
        - x: 340
          "y": 298
        - x: 340
          "y": 460
        - x: 380
          "y": 460
    Flow_Random_Join:
      type: bpmn:SequenceFlow
      sourceRef: Agent_Random
      targetRef: Join
      waypoint:
        - x: 500
          "y": 140
        - x: 540
          "y": 140
        - x: 540
          "y": 298
        - x: 560
          "y": 298
    Flow_Claude_Join:
      type: bpmn:SequenceFlow
      sourceRef: Agent_Claude
      targetRef: Join
      waypoint:
        - x: 500
          "y": 298
        - x: 560
          "y": 298
    Flow_Ollama_Join:
      type: bpmn:SequenceFlow
      sourceRef: Agent_Ollama
      targetRef: Join
      waypoint:
        - x: 500
          "y": 460
        - x: 540
          "y": 460
        - x: 540
          "y": 298
        - x: 560
          "y": 298
    Flow_Join_Score:
      type: bpmn:SequenceFlow
      sourceRef: Join
      targetRef: Score
      waypoint:
        - x: 610
          "y": 298
        - x: 660
          "y": 298
    Flow_Score_End:
      type: bpmn:SequenceFlow
      sourceRef: Score
      targetRef: End
      waypoint:
        - x: 800
          "y": 298
        - x: 860
          "y": 298
  artifacts:
    Assoc_Score_Data:
      type: bpmn:Association
      associationDirection: One
      sourceRef: Score
      targetRef: Dataset_Responses
      waypoint:
        - x: 730
          "y": 338
        - x: 730
          "y": 430
  isExecutable: false
