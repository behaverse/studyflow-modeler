<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:studyflow="http://behaverse.org/schemas/studyflow" xmlns:cognitive="http://behaverse.org/schemas/studyflow/cognitive" xmlns:behaverse="http://behaverse.org/schemas/studyflow/behaverse" id="agent_eval_pool" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn2:process id="Agent_Eval_Pool" name="LLM evaluation — agent actor pool" isExecutable="false">
    <bpmn2:extensionElements>
      <studyflow:study />
    </bpmn2:extensionElements>
    <bpmn2:documentation>An LLM-evaluation study: a pool of automated agent actors — a random baseline, a Claude LLM, and a local Ollama LLM — each complete the same 2-back protocol in parallel. Their responses are aggregated so the models can be compared against the baseline and against human norms. Each branch reuses the bot configuration from the shipped bot_external / bot_claude / bot_ollama demos.</bpmn2:documentation>
    <bpmn2:startEvent id="Start" name="Load N-Back protocol">
      <bpmn2:outgoing>Flow_Start_Fork</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:parallelGateway id="Fork" name="Dispatch to agent pool">
      <bpmn2:incoming>Flow_Start_Fork</bpmn2:incoming>
      <bpmn2:outgoing>Flow_Fork_Random</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_Fork_Claude</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_Fork_Ollama</bpmn2:outgoing>
    </bpmn2:parallelGateway>
    <bpmn2:task id="Agent_Random" name="Random baseline agent">
      <bpmn2:extensionElements>
        <behaverse:task scene="NB" agentType="bot">
        <behaverse:botConfigurations>ResponseSource: external
Speed: 20
SkipInstructions: true
AutoClickInstructions: true
SkipFocusArea: true
OverrideTemporalParameters: true
StimulusDisplayDuration: 0.3
InterStimulusInterval: 0.3
TrialForeperiod: 0.1</behaverse:botConfigurations>
        <cognitive:configurations>Blocks:
  Eval_2Back:
    Name: Eval_2Back
    Inherits: Default
    Parameters:
      NValue: 2
      Feature: Letters
      Streams:
        - Feature:
            Reference: Feature
          StimulusValue:
            Generate: OncePerBlock
            Sequence:
              Type: Ordered
              Values: [3, 1, 2, 1, 3, 2, 3, 2, 1, 2, 3, 1]
      StreamSize: 12
      FeatureValuesCount: 3
      MaxResponseTime: 2
      StimulusDisplayDuration: 0.5
      InterStimulusInterval: 1.5
Timelines:
  Eval_2Back:
    Name: Eval_2Back
    blocks:
      - name: Eval_2Back
</cognitive:configurations>
      </behaverse:task>
      </bpmn2:extensionElements>
      <bpmn2:documentation>Uniformly-random responder — the chance baseline every model is compared against.</bpmn2:documentation>
      <bpmn2:incoming>Flow_Fork_Random</bpmn2:incoming>
      <bpmn2:outgoing>Flow_Random_Join</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Agent_Claude" name="Claude LLM agent">
      <bpmn2:extensionElements>
        <behaverse:task scene="NB" agentType="bot">
        <behaverse:botConfigurations>ResponseSource: llm
LLM:
  Provider: claude
  Model: claude-haiku-4-5
Prompt: |
  You are an attentive, expert participant in a 2-back task.
  Respond Match if the current letter is identical to the letter shown
  exactly two trials ago, otherwise NonMatch. Aim for near-perfect
  accuracy. Reply with exactly Match or NonMatch; no explanation.
Speed: 20
SkipInstructions: true
AutoClickInstructions: true
SkipFocusArea: true
OverrideTemporalParameters: true
StimulusDisplayDuration: 0.3
InterStimulusInterval: 0.3
TrialForeperiod: 0.1
overrideUserInputParameters: true
playerPaced: true
useNonMatchButton: true
maxResponseTime: 120</behaverse:botConfigurations>
        <cognitive:configurations>Blocks:
  Eval_2Back:
    Name: Eval_2Back
    Inherits: Default
    Parameters:
      NValue: 2
      Feature: Letters
      Streams:
        - Feature:
            Reference: Feature
          StimulusValue:
            Generate: OncePerBlock
            Sequence:
              Type: Ordered
              Values: [3, 1, 2, 1, 3, 2, 3, 2, 1, 2, 3, 1]
      StreamSize: 12
      FeatureValuesCount: 3
      MaxResponseTime: 30
      StimulusDisplayDuration: 0.5
      InterStimulusInterval: 1.5
Timelines:
  Eval_2Back:
    Name: Eval_2Back
    blocks:
      - name: Eval_2Back
</cognitive:configurations>
      </behaverse:task>
      </bpmn2:extensionElements>
      <bpmn2:documentation>Claude-powered LLM actor completing the shared 2-back protocol via text stimuli.</bpmn2:documentation>
      <bpmn2:incoming>Flow_Fork_Claude</bpmn2:incoming>
      <bpmn2:outgoing>Flow_Claude_Join</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Agent_Ollama" name="Ollama LLM agent (local)">
      <bpmn2:extensionElements>
        <behaverse:task scene="NB" agentType="bot">
        <behaverse:botConfigurations>ResponseSource: llm
LLM:
  Provider: ollama
  Model: gemma4:e2b-mlx
Prompt: |
  You are an attentive, expert participant in a 2-back task.
  Respond Match if the current letter is identical to the letter shown
  exactly two trials ago, otherwise NonMatch. Aim for near-perfect
  accuracy. Reply with exactly Match or NonMatch; no explanation.
Speed: 20
SkipInstructions: true
AutoClickInstructions: true
SkipFocusArea: true
OverrideTemporalParameters: true
StimulusDisplayDuration: 0.3
InterStimulusInterval: 0.3
TrialForeperiod: 0.1
overrideUserInputParameters: true
playerPaced: true
useNonMatchButton: true
maxResponseTime: 15</behaverse:botConfigurations>
        <cognitive:configurations>Blocks:
  Eval_2Back:
    Name: Eval_2Back
    Inherits: Default
    Parameters:
      NValue: 2
      Feature: Letters
      Streams:
        - Feature:
            Reference: Feature
          StimulusValue:
            Generate: OncePerBlock
            Sequence:
              Type: Ordered
              Values: [3, 1, 2, 1, 3, 2, 3, 2, 1, 2, 3, 1]
      StreamSize: 12
      FeatureValuesCount: 3
      MaxResponseTime: 15
      StimulusDisplayDuration: 0.5
      InterStimulusInterval: 1.5
Timelines:
  Eval_2Back:
    Name: Eval_2Back
    blocks:
      - name: Eval_2Back
</cognitive:configurations>
      </behaverse:task>
      </bpmn2:extensionElements>
      <bpmn2:documentation>Local Ollama model acting as an agent on the same 2-back protocol; no data leaves the machine.</bpmn2:documentation>
      <bpmn2:incoming>Flow_Fork_Ollama</bpmn2:incoming>
      <bpmn2:outgoing>Flow_Ollama_Join</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:parallelGateway id="Join" name="Collect responses">
      <bpmn2:incoming>Flow_Random_Join</bpmn2:incoming>
      <bpmn2:incoming>Flow_Claude_Join</bpmn2:incoming>
      <bpmn2:incoming>Flow_Ollama_Join</bpmn2:incoming>
      <bpmn2:outgoing>Flow_Join_Score</bpmn2:outgoing>
    </bpmn2:parallelGateway>
    <bpmn2:task id="Score" name="Aggregate &amp; compare accuracy" studyflow:checklist="- [ ] Compute hit rate / false-alarm rate per agent&#10;- [ ] Compute d-prime per agent&#10;- [ ] Compare each model to the random baseline&#10;- [ ] Compare models to human norms">
      <bpmn2:documentation>Aggregate the per-agent response streams into a common table and score each actor against the random baseline and human norms.</bpmn2:documentation>
      <bpmn2:incoming>Flow_Join_Score</bpmn2:incoming>
      <bpmn2:outgoing>Flow_Score_End</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:dataStoreReference id="Dataset_Responses" name="Agent response set">
      <bpmn2:extensionElements>
        <studyflow:dataset format="bdm" bdmDataLevel="trials" />
      </bpmn2:extensionElements>
    </bpmn2:dataStoreReference>
    <bpmn2:endEvent id="End" name="Evaluation report">
      <bpmn2:incoming>Flow_Score_End</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="Flow_Start_Fork" sourceRef="Start" targetRef="Fork" />
    <bpmn2:sequenceFlow id="Flow_Fork_Random" sourceRef="Fork" targetRef="Agent_Random" />
    <bpmn2:sequenceFlow id="Flow_Fork_Claude" sourceRef="Fork" targetRef="Agent_Claude" />
    <bpmn2:sequenceFlow id="Flow_Fork_Ollama" sourceRef="Fork" targetRef="Agent_Ollama" />
    <bpmn2:sequenceFlow id="Flow_Random_Join" sourceRef="Agent_Random" targetRef="Join" />
    <bpmn2:sequenceFlow id="Flow_Claude_Join" sourceRef="Agent_Claude" targetRef="Join" />
    <bpmn2:sequenceFlow id="Flow_Ollama_Join" sourceRef="Agent_Ollama" targetRef="Join" />
    <bpmn2:sequenceFlow id="Flow_Join_Score" sourceRef="Join" targetRef="Score" />
    <bpmn2:sequenceFlow id="Flow_Score_End" sourceRef="Score" targetRef="End" />
    <bpmn2:association id="Assoc_Score_Data" associationDirection="One" sourceRef="Score" targetRef="Dataset_Responses" />
  </bpmn2:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Agent_Eval_Pool">
      <bpmndi:BPMNShape id="Start_di" bpmnElement="Start">
        <dc:Bounds x="160" y="280" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="140" y="323" width="78" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Fork_di" bpmnElement="Fork">
        <dc:Bounds x="250" y="273" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="236" y="330" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Agent_Random_di" bpmnElement="Agent_Random">
        <dc:Bounds x="380" y="100" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Agent_Claude_di" bpmnElement="Agent_Claude">
        <dc:Bounds x="380" y="258" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Agent_Ollama_di" bpmnElement="Agent_Ollama">
        <dc:Bounds x="380" y="420" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Join_di" bpmnElement="Join">
        <dc:Bounds x="560" y="273" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="548" y="330" width="76" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Score_di" bpmnElement="Score">
        <dc:Bounds x="660" y="258" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Dataset_Responses_di" bpmnElement="Dataset_Responses">
        <dc:Bounds x="705" y="430" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="688" y="485" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_di" bpmnElement="End">
        <dc:Bounds x="860" y="280" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="838" y="323" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_Fork_di" bpmnElement="Flow_Start_Fork">
        <di:waypoint x="196" y="298" />
        <di:waypoint x="250" y="298" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Fork_Random_di" bpmnElement="Flow_Fork_Random">
        <di:waypoint x="300" y="298" />
        <di:waypoint x="340" y="298" />
        <di:waypoint x="340" y="140" />
        <di:waypoint x="380" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Fork_Claude_di" bpmnElement="Flow_Fork_Claude">
        <di:waypoint x="300" y="298" />
        <di:waypoint x="380" y="298" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Fork_Ollama_di" bpmnElement="Flow_Fork_Ollama">
        <di:waypoint x="300" y="298" />
        <di:waypoint x="340" y="298" />
        <di:waypoint x="340" y="460" />
        <di:waypoint x="380" y="460" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Random_Join_di" bpmnElement="Flow_Random_Join">
        <di:waypoint x="500" y="140" />
        <di:waypoint x="540" y="140" />
        <di:waypoint x="540" y="298" />
        <di:waypoint x="560" y="298" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Claude_Join_di" bpmnElement="Flow_Claude_Join">
        <di:waypoint x="500" y="298" />
        <di:waypoint x="560" y="298" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Ollama_Join_di" bpmnElement="Flow_Ollama_Join">
        <di:waypoint x="500" y="460" />
        <di:waypoint x="540" y="460" />
        <di:waypoint x="540" y="298" />
        <di:waypoint x="560" y="298" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Join_Score_di" bpmnElement="Flow_Join_Score">
        <di:waypoint x="610" y="298" />
        <di:waypoint x="660" y="298" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Score_End_di" bpmnElement="Flow_Score_End">
        <di:waypoint x="800" y="298" />
        <di:waypoint x="860" y="298" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Assoc_Score_Data_di" bpmnElement="Assoc_Score_Data">
        <di:waypoint x="730" y="338" />
        <di:waypoint x="730" y="430" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn2:definitions>
