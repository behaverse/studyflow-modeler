id: function_call_demo
definitions:
  targetNamespace: http://bpmn.io/schema/bpmn
  xmlns:xsi: http://www.w3.org/2001/XMLSchema-instance
  xmlns:bpmn2: http://www.omg.org/spec/BPMN/20100524/MODEL
  xmlns:bpmndi: http://www.omg.org/spec/BPMN/20100524/DI
  xmlns:dc: http://www.omg.org/spec/DD/20100524/DC
  xmlns:di: http://www.omg.org/spec/DD/20100524/DI
  xmlns:studyflow: http://behaverse.org/schemas/studyflow/v1
  xmlns:datatrove: https://w3id.org/studyflow/datatrove
  xmlns:exec: https://w3id.org/studyflow/exec
FunctionCallDemo:
  type: bpmn:Process
  documentation: Demonstrates function references by binding a Map to a python callable and fetching a script by URL.
  extensionElements:
    - type: studyflow:Study
  name: Function calls demo
  flowElements:
    Start:
      type: bpmn:StartEvent
      name: Start
      outgoing:
        - Flow_Start_Map
      bounds:
        x: 162
        "y": 182
        width: 36
        height: 36
      label:
        bounds:
          x: 168
          "y": 225
          width: 24
          height: 14
    MapRT:
      type: bpmn:ServiceTask
      extensionElements:
        - type: datatrove:Map
      name: Median RT per block
      incoming:
        - Flow_Start_Map
      outgoing:
        - Flow_Map_Fetch
      isDataOperation: true
      with:
        column: rt
        fn: median
      implementation: python://pkg_for_st.do_map@1.2
      studyflow:operationType: map
      bounds:
        x: 260
        "y": 160
        width: 100
        height: 80
    FetchScript:
      type: bpmn:ServiceTask
      name: Fetch cleaning script
      incoming:
        - Flow_Map_Fetch
      outgoing:
        - Flow_Fetch_End
      implementation: https://example.org/scripts/clean.py@v2
      bounds:
        x: 420
        "y": 160
        width: 100
        height: 80
    End:
      type: bpmn:EndEvent
      name: Done
      incoming:
        - Flow_Fetch_End
      bounds:
        x: 582
        "y": 182
        width: 36
        height: 36
      label:
        bounds:
          x: 589
          "y": 225
          width: 24
          height: 14
    Flow_Start_Map:
      type: bpmn:SequenceFlow
      sourceRef: Start
      targetRef: MapRT
      waypoint:
        - x: 198
          "y": 200
        - x: 260
          "y": 200
    Flow_Map_Fetch:
      type: bpmn:SequenceFlow
      sourceRef: MapRT
      targetRef: FetchScript
      waypoint:
        - x: 360
          "y": 200
        - x: 420
          "y": 200
    Flow_Fetch_End:
      type: bpmn:SequenceFlow
      sourceRef: FetchScript
      targetRef: End
      waypoint:
        - x: 520
          "y": 200
        - x: 582
          "y": 200
  isExecutable: true
