id: demo4_llm_bot
definitions:
  targetNamespace: http://bpmn.io/schema/bpmn
  xmlns:xsi: http://www.w3.org/2001/XMLSchema-instance
  xmlns:bpmn2: http://www.omg.org/spec/BPMN/20100524/MODEL
  xmlns:bpmndi: http://www.omg.org/spec/BPMN/20100524/DI
  xmlns:dc: http://www.omg.org/spec/DD/20100524/DC
  xmlns:di: http://www.omg.org/spec/DD/20100524/DI
  xmlns:studyflow: http://behaverse.org/schemas/studyflow/v1
  xmlns:cognitive: http://behaverse.org/schemas/studyflow/cognitive
  xmlns:behaverse: http://behaverse.org/schemas/studyflow/behaverse
Demo4_LLMBot:
  type: bpmn:Process
  extensionElements:
    - type: studyflow:Study
  name: LLM bot (Claude Code)
  flowElements:
    Start:
      type: bpmn:StartEvent
      name: Start
      outgoing:
        - Flow_Start_Warmup
      bounds:
        x: 160
        "y": 180
        width: 36
        height: 36
      label:
        bounds:
          x: 166
          "y": 223
          width: 24
          height: 14
    Warmup_1Back:
      type: bpmn:Task
      extensionElements:
        - type: behaverse:Task
          configurations:
            Blocks:
              Demo4_Warmup:
                Name: Demo4_Warmup
                Inherits: Default
                Parameters:
                  NValue: 1
                  Feature: Letters
                  Streams:
                    - Feature:
                        Reference: Feature
                      StimulusValue:
                        Generate: OncePerBlock
                        Sequence:
                          Type: Ordered
                          Values:
                            - 3
                            - 1
                            - 2
                            - 1
                            - 3
                            - 2
                            - 3
                            - 2
                  StreamSize: 8
                  FeatureValuesCount: 3
                  MaxResponseTime: 30
                  StimulusDisplayDuration: 0.5
                  InterStimulusInterval: 1.5
            Timelines:
              Demo4_Warmup:
                Name: Demo4_Warmup
                blocks:
                  - name: Demo4_Warmup
          scene: NB
          agentType: bot
          botConfigurations:
            ResponseSource: llm
            LLM:
              Provider: claude
              Model: claude-haiku-4-5
            Prompt: |
              You are a tired participant near the end of a long 1-back session.
              Aim for about 80% accuracy. Occasionally miss matches when your
              attention drifts. Never explain; reply with exactly Match or NonMatch.
            Speed: 20
            SkipInstructions: true
            AutoClickInstructions: true
            SkipFocusArea: true
            OverrideTemporalParameters: true
            StimulusDisplayDuration: 0.3
            InterStimulusInterval: 0.3
            TrialForeperiod: 0.1
            overrideUserInputParameters: true
            playerPaced: true
            useNonMatchButton: true
            maxResponseTime: 120
      name: 1-Back warm-up (tired)
      incoming:
        - Flow_Start_Warmup
      outgoing:
        - Flow_Warmup_Main
      bounds:
        x: 260
        "y": 158
        width: 120
        height: 80
    Main_2Back:
      type: bpmn:Task
      extensionElements:
        - type: behaverse:Task
          configurations:
            Blocks:
              Demo4_Main:
                Name: Demo4_Main
                Inherits: Default
                Parameters:
                  NValue: 2
                  Feature: Letters
                  Streams:
                    - Feature:
                        Reference: Feature
                      StimulusValue:
                        Generate: OncePerBlock
                        Sequence:
                          Type: Ordered
                          Values:
                            - 3
                            - 1
                            - 2
                            - 1
                            - 3
                            - 2
                            - 3
                            - 2
                            - 1
                            - 2
                            - 3
                            - 1
                  StreamSize: 12
                  FeatureValuesCount: 3
                  MaxResponseTime: 30
                  StimulusDisplayDuration: 0.5
                  InterStimulusInterval: 1.5
            Timelines:
              Demo4_Main:
                Name: Demo4_Main
                blocks:
                  - name: Demo4_Main
          scene: NB
          agentType: bot
          botConfigurations:
            ResponseSource: llm
            LLM:
              Provider: claude
              Model: claude-haiku-4-5
            Prompt: |
              You are an attentive, expert participant in a 2-back task.
              Respond Match if the current letter is identical to the letter shown
              exactly two trials ago, otherwise NonMatch. Aim for near-perfect
              accuracy. Reply with exactly Match or NonMatch; no explanation.
            Speed: 20
            SkipInstructions: true
            AutoClickInstructions: true
            SkipFocusArea: true
            OverrideTemporalParameters: true
            StimulusDisplayDuration: 0.3
            InterStimulusInterval: 0.3
            TrialForeperiod: 0.1
            overrideUserInputParameters: true
            playerPaced: true
            useNonMatchButton: true
            maxResponseTime: 120
      name: 2-Back main (expert)
      incoming:
        - Flow_Warmup_Main
      outgoing:
        - Flow_Main_Visual
      bounds:
        x: 450
        "y": 158
        width: 120
        height: 80
    Visual_WhichOne:
      type: bpmn:Task
      extensionElements:
        - type: behaverse:Task
          configurations:
            Timelines:
              SimonTask: null
          scene: WO
          agentType: bot
          botConfigurations:
            ResponseSource: llm
            IncludeScreenshot: true
            LLM:
              Provider: claude
              Model: claude-haiku-4-5
            Prompt: |
              You will see a screenshot from the WhichOne task. Two stimuli appear
              on the left and right of the screen; one matches a target shown above.
              Reply with exactly `Left` or `Right`; nothing else.
            Speed: 5
            SkipInstructions: true
            AutoClickInstructions: true
            SkipFocusArea: true
      name: WhichOne (vision)
      incoming:
        - Flow_Main_Visual
      outgoing:
        - Flow_Visual_End
      bounds:
        x: 640
        "y": 158
        width: 120
        height: 80
    End:
      type: bpmn:EndEvent
      name: Done
      incoming:
        - Flow_Visual_End
      bounds:
        x: 830
        "y": 180
        width: 36
        height: 36
      label:
        bounds:
          x: 837
          "y": 223
          width: 22
          height: 14
    Flow_Start_Warmup:
      type: bpmn:SequenceFlow
      sourceRef: Start
      targetRef: Warmup_1Back
      waypoint:
        - x: 196
          "y": 198
        - x: 260
          "y": 198
    Flow_Warmup_Main:
      type: bpmn:SequenceFlow
      sourceRef: Warmup_1Back
      targetRef: Main_2Back
      waypoint:
        - x: 380
          "y": 198
        - x: 450
          "y": 198
    Flow_Main_Visual:
      type: bpmn:SequenceFlow
      sourceRef: Main_2Back
      targetRef: Visual_WhichOne
      waypoint:
        - x: 570
          "y": 198
        - x: 640
          "y": 198
    Flow_Visual_End:
      type: bpmn:SequenceFlow
      sourceRef: Visual_WhichOne
      targetRef: End
      waypoint:
        - x: 760
          "y": 198
        - x: 830
          "y": 198
