<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:studyflow="http://behaverse.org/schemas/studyflow" xmlns:behaverse="http://behaverse.org/schemas/studyflow/behaverse" id="verify_wo" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn2:process id="VerifyWO" name="WO bound check">
    <bpmn2:extensionElements><studyflow:study /></bpmn2:extensionElements>
    <bpmn2:startEvent id="Start"><bpmn2:outgoing>F_WO</bpmn2:outgoing></bpmn2:startEvent>
    <bpmn2:task id="T_WO" name="WO"><bpmn2:extensionElements><behaverse:behaverseTask scene="WO" configMode="builtin" agentMode="bot" timelineId="Debug" botConfig="ResponseSource: external&#10;Speed: 100&#10;SkipInstructions: true&#10;AutoClickInstructions: true&#10;SkipFocusArea: true" /></bpmn2:extensionElements><bpmn2:incoming>F_WO</bpmn2:incoming><bpmn2:outgoing>F_End</bpmn2:outgoing></bpmn2:task>
    <bpmn2:endEvent id="End"><bpmn2:incoming>F_End</bpmn2:incoming></bpmn2:endEvent>
    <bpmn2:sequenceFlow id="F_WO" sourceRef="Start" targetRef="T_WO" />
    <bpmn2:sequenceFlow id="F_End" sourceRef="T_WO" targetRef="End" />
  </bpmn2:process>
  <bpmndi:BPMNDiagram id="D1"><bpmndi:BPMNPlane id="P1" bpmnElement="VerifyWO"></bpmndi:BPMNPlane></bpmndi:BPMNDiagram>
</bpmn2:definitions>
